SECRET_KEY=change-me-generate-with-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_PATH=data/db.sqlite3
LEXIKON_DB_PATH=data/lexikon.sqlite3

# Nur fuer Produktion/Docker relevant - lokal mit DEBUG=True nicht noetig.
CSRF_TRUSTED_ORIGINS=
MEDIA_ROOT=media

# Optional: legt beim ersten Start automatisch einen Admin-Account an, falls
# noch keiner existiert (siehe apps/accounts/management/commands/create_admin.py).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
